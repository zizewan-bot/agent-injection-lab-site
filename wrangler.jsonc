{
  "name": "agent-injection-lab-site",
  "main": "worker/index.js",
  "compatibility_date": "2026-05-30",
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*"
    ]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "agent_injection_lab_observations",
      "database_id": "TODO_D1_DATABASE_ID"
    }
  ]
}
